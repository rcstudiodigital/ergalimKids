# ── JWT (segurança) ─────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VITE_JWT_SECRET=cole_aqui_uma_string_aleatoria_longa

# ── Credenciais de acesso (só para demo local) ───────────────────────
VITE_ADMIN_EMAIL=admin@ergalimkids.com
VITE_ADMIN_PASS=SuaSenhaAdminForte123!

VITE_OWNER_EMAIL=Gabrieldarochafurtado1996@gmail.com
VITE_OWNER_PASS=SuaSenhaDono123!

# ── Dados da loja ───────────────────────────────────────────────────
VITE_STORE_EMAIL=Gabrieldarochafurtado1996@gmail.com

# ── Mercado Pago (chave PÚBLICA — pode estar no frontend) ───────────
# Pegue em: mercadopago.com.br → Seu negócio → Credenciais → Produção
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── E-mails automáticos (Resend — grátis 3.000/mês) ────────────────
# Crie conta em resend.com → API Keys → Create API Key
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════════
