# ─────────────────────────────────────────────────────────────
# Ergalim Kids — Template de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus dados reais.
# NUNCA coloque dados reais aqui — este arquivo é versionado no Git.
# ─────────────────────────────────────────────────────────────

# Firebase (públicas por design — protegidas pelas regras do Firestore)
VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123

# Cloudinary (upload de imagens)
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=seu_preset

# Logins de staff (e-mails — as SENHAS ficam no servidor, em api/auth.js)
VITE_ADMIN_EMAIL=admin@sualojaexemplo.com
VITE_OWNER_EMAIL=dono@sualojaexemplo.com

# Senhas de DEV apenas (modo local) — em produção use a serverless /api/auth
VITE_DEV_ADMIN_PASS=
VITE_DEV_OWNER_PASS=

# ─────────────────────────────────────────────────────────────
# As variáveis abaixo são SECRETAS e ficam SÓ na Vercel (sem VITE_)
# Não precisam estar no .env.local do frontend.
# ─────────────────────────────────────────────────────────────
# ADMIN_EMAIL / ADMIN_PASS / OWNER_EMAIL / OWNER_PASS  (api/auth.js)
# RESEND_API_KEY                                       (api/send-email.js)
# MELHOR_ENVIO_TOKEN / CEP_ORIGEM                      (api/shipping.js)
# MERCADOPAGO_ACCESS_TOKEN / SITE_URL                  (api/payment/*)
