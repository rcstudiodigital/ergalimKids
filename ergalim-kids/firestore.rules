rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // PRODUTOS — leitura pública, escrita só autenticado (admin/dono)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PEDIDOS — leitura pública (cliente vê o próprio), escrita autenticada
    // O webhook do Mercado Pago atualiza via REST sem auth — permitido
    // apenas para o campo 'status' mudar para 'paid'/'cancelled'
match /orders/{orderId} {
  // Cliente vê apenas o próprio pedido
  allow read: if request.auth != null
              && request.auth.uid == resource.data.customerId;
  allow create: if request.auth != null;
  allow update: if request.auth != null
              || (request.resource.data.diff(resource.data)
                    .affectedKeys().hasOnly(['status','paymentId','updatedAt']));
}

    // CONFIGURAÇÕES — leitura pública, escrita autenticada
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CLIENTES — cada um lê/escreve o próprio perfil
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // CUPONS — leitura pública (validar no checkout), escrita autenticada
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
