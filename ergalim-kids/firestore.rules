rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // PRODUTOS — leitura pública, escrita só autenticado (admin/dono)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PEDIDOS — leitura pública (cliente vê o próprio), escrita autenticada
    // O webhook do Mercado Pago atualiza via REST sem auth — permitido
    // apenas para o campo 'status' mudar para 'paid'/'cancelled'
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    // OU é o webhook atualizando status de pagamento
                    || (request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'paymentId', 'updatedAt']));
      allow delete: if request.auth != null;
    }

    // CONFIGURAÇÕES — leitura pública, escrita autenticada
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CLIENTES — cada um lê/escreve o próprio perfil
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // CUPONS — leitura pública (validar no checkout), escrita autenticada
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
