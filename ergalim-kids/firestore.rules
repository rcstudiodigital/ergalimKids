rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // PRODUTOS — leitura pública, escrita só autenticado (admin/dono)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PEDIDOS — leitura liberada para usuário autenticado (cliente, admin e dono
    // leem via login anônimo do Firebase). O webhook do Mercado Pago atualiza
    // o status via REST mesmo sem auth, mas só os campos de pagamento.
    //
    // OBS: a separação "cada cliente só lê o próprio pedido" exige um backend
    // com Firebase Admin SDK (auth.uid != customerId no modelo atual).
    // Fica como melhoria futura — hoje liberar a leitura autenticada é o que
    // mantém o painel e a conta do cliente funcionando.
    match /orders/{orderId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    || request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['status','paymentId','updatedAt']);
      allow delete: if request.auth != null;
    }

    // CONFIGURAÇÕES — leitura pública, escrita autenticada
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CLIENTES — cada um lê/escreve o próprio perfil (autenticado)
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // CUPONS — leitura pública (validar no checkout), escrita autenticada
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
